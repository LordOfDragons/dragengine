import SCons

from SConsCommon import *
from SConsExternCommon import *

Import('parent_env parent_targets parent_report')

envLibrary = parent_env.Clone()

buildStaticLinking = True

libversion = '1.6.1'
srcdir = 'opus-{}'.format(libversion)

libLinkVersion = '0'
libLinkName = 'opus'

if envLibrary['OSWindows']:
	libFileName = 'bin/lib{}-{}.dll'.format(libLinkName, libLinkVersion)
	staticFileName = 'lib/lib{}.a'.format(libLinkName)
else:
	libFileName = envLibrary.subst('lib/${{SHLIBPREFIX}}{}${{SHLIBSUFFIX}}.{}'.format(libLinkName, libLinkVersion))
	staticFileName = envLibrary.subst('lib/${{LIBPREFIX}}{}${{LIBSUFFIX}}'.format(libLinkName))

# fetching is always allowed
nodeArtifacts = envLibrary.DownloadArtifactHelper('{}.tar.xz'.format(srcdir), 'libopus', 'lib_libopus_fetch')

# check if system libopus is present
hasSystemOPUS = False
conf = envLibrary.Configure()
if envLibrary['with_system_libopus'] != TernaryVariableNo:
	hasSystemOPUS = conf.CheckLibWithHeader(libLinkName, 'opus/opus.h', 'c++', call='opus_encoder_get_size(1);')
conf.Finish()

if not hasSystemOPUS and envLibrary['with_system_libopus'] == TernaryVariableYes:
	Exit('Requested to use system libopus but no usable libopus found.')

libs = [libLinkName]

parent_report['use system libopus'] = 'yes' if hasSystemOPUS else 'no'

if hasSystemOPUS:
	parent_targets['lib_libopus'] = {
		'name' : 'Internal libopus library',
		'cpppath' : [],
		'libpath' : [],
		'libs' : libs,
		'runtimelibs' : [],
		'depends' : []
	}
	Return()

# build libopus
def libopusBuild(target, source, env):
	buildDir = target[0].get_dir().up()
	
	untarArchive(buildDir.abspath, source[0].abspath)
	
	script = createScriptHeader(env)
	
	script.append('cd "{}" || exit 1'.format(buildDir.Dir(srcdir).abspath))
	
	cmdline = ['./configure --prefix="{}"'.format(buildDir.abspath)]
	cmdline.append('--enable-silent-rules')
	cmdline.append('--disable-dependency-tracking')
	cmdline.append('--disable-doc')
	cmdline.append('--disable-dot-product')
	cmdline.append('--disable-extra-programs')
	# cmdline.append('--enable-dred') # use Deep REDundancy (DRED)
	# cmdline.append('--enable-deep-plc') # use deep PLC for SILK
	# cmdline.append('--enable-float-approx') # enable fast approximations for floating point
	# cmdline.append('--enable-osce-training-data') # enable feature output for SILK enhancement
	# cmdline.append('--enable-osce') # enable speech coding enhancement
	if buildStaticLinking:
		cmdline.append('--enable-shared=no')
		cmdline.append('--enable-static=yes')
		cmdline.append('--with-pic=yes')
	else:
		cmdline.append('--enable-shared=yes')
		cmdline.append('--enable-static=no')
	
	if env['platform_webwasm']:
		cmdline.append('--disable-rtcd')
		# cmdline.append('--disable-intrinsics')
	
	if 'CROSSCOMPILE_HOST' in env:
		cmdline.append('--host={}'.format(env['CROSSCOMPILE_HOST']))
	
	script.append('{} || exit 1'.format(' '.join(cmdline)))
	
	script.append('make -j {} install || exit 1'.format(env['with_threads']))
	
	if not env.RunExternalCommand(script):
		raise Exception('Failed building libogg')

targets = [staticFileName if buildStaticLinking else libFileName]
targets.extend([
	'include/opus/opus.h',
	'include/opus/opus_defines.h',
	'include/opus/opus_types.h',
	'include/opus/opus_multistream.h',
	'include/opus/opus_projection.h'
])
library = envLibrary.Command(targets, nodeArtifacts, envLibrary.Action(libopusBuild, 'Build libopus'))

depends = parent_env.Alias('lib_libopus', library)

envLibrary.Clean(library, ['include', 'lib', 'share', srcdir])

if buildStaticLinking:
	libs = [library[0]]
	runtimelibs = []
else:
	runtimelibs = [library[0]]

parent_targets['lib_libopus'] = {
	'name' : 'Internal libopus library',
	'cpppath' : [envLibrary.Dir('include')],
	'libpath' : [envLibrary.Dir('lib')],
	'libs' : libs,
	'runtimelibs' : runtimelibs,
	'depends' : depends
}
