namespace Dragengine.Audio.LipSync
pin Dragengine.Scenery

/**
 * \brief Lip synchronization for jaw flapping.
 * 
 * Provides jaw flapping lip synchronization. For more details see \ref LipSync.
 */
class LipSyncJawFlaping extends LipSync
	var float pOpenMouthLevel
	
	
	/**
	 * \brief Create lip sync.
	 */
	func new()
		pOpenMouthLevel = 0.35
		
		var AudioAnalyzer analyzer = getAudioAnalyzer()
		analyzer.setSampleRate(16000)
		analyzer.setResolution(512)
		analyzer.setFrequencyBandCount(1)
		analyzer.setFrequencyRange(20, 8000)
	end
	
	
	/**
	 * \brief Open mouth sound level.
	 * 
	 * Sound level where jaw is fully open. Value is measured in RMS (root mean square).
	 * Default value is 0.35.
	 */
	func float getOpenMouthLevel()
		return pOpenMouthLevel
	end
	
	/**
	 * \brief Set open mouth sound level.
	 * 
	 * Sound level where jaw is fully open. Value is measured in RMS (root mean square).
	 */
	func void setOpenMouthLevel(float level)
		pOpenMouthLevel = Math.clamp(level, 0.0, 1.0)
	end
	
	
	
	func void update(float elapsed)
		getAudioAnalyzer().updateResults()
		
		setJawOpeness(DEMath.smoothStep(getAudioAnalyzer().getRMS(), getNoiseFloor(), pOpenMouthLevel))
		
		setVisemeSubsetFromJawOpeness()
		setVisemeFullFromSubset()
		
		smoothResults(elapsed)
	end
end
